{
  "version": 2,
  "builds": [
    { "src": "vault/package.json", "use": "@vercel/next" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/vault(.*)", "dest": "/vault$1" },
    { "src": "/(.*\\.html)$", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
